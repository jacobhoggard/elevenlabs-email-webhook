{
  "version": 2,
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "env": {
    "RESEND_API_KEY": "@resend_api_key",
    "ELEVENLABS_WEBHOOK_SECRET": "@elevenlabs_webhook_secret",
    "EMAIL_FROM": "noreply@sanctuarywanaka.com"
  },
  "functions": {
    "api/webhook.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
